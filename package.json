{
  "name": "clawbraints",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript migration of ClawBrain core services",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node dist/scripts/migrate.js",
    "worker": "node dist/runner/worker.js",
    "maintainer": "node dist/runner/maintainer.js",
    "autotune": "node dist/runner/autotune.js",
    "ide-cli": "node dist/ide_client/cli.js",
    "mcp-server": "node dist/ide_client/mcp_server.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^14.0.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.6.1",
    "js-yaml": "^4.1.0",
    "string-argv": "^0.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
