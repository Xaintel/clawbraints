CLAWBRAIN_MEMORY_DIR=/data/clawbrain/memory
CLAWBRAIN_ARTIFACTS_DIR=/data/clawbrain/artifacts
CLAWBRAIN_SECRETS_DIR=/data/clawbrain/secrets
