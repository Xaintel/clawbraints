#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"

if [[ ! -d node_modules ]]; then
  npm install >/dev/null
fi
if [[ ! -f dist/scripts/configure_local_policy.js ]]; then
  npm run build >/dev/null
fi

exec node dist/scripts/configure_local_policy.js "$@"
