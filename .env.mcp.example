# MCP runtime config for scripts/clawbrain-mcp-server-auto
# Copy to .env.mcp and adjust values.

# Brain API base URL
CLAWBRAIN_IDE_SERVER_URL=http://127.0.0.1:8088
# Local mode example:
# CLAWBRAIN_IDE_SERVER_URL=http://127.0.0.1:18088

# Option A: token inline (not recommended for shared hosts)
# CLAWBRAIN_IDE_TOKEN=replace-with-token

# Option B: token from file (recommended)
CLAWBRAIN_IDE_TOKEN_FILE=/data/clawbrain/secrets/api_token
# Local mode example:
# CLAWBRAIN_IDE_TOKEN_FILE=/srv/clawbrain/clawbrain-brain/.local/data/secrets/api_token
